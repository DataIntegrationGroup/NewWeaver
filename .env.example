# Copy to .env and fill in. Vite only exposes vars prefixed with VITE_.

# PostHog product analytics. Leave VITE_POSTHOG_KEY empty to disable tracking
# (dev/CI emit nothing without it). Events are sent through the /ingest reverse
# proxy (see vite.config.ts and nginx/default.conf.template).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Upstream service endpoint overrides (optional — defaults live in src/config.ts).
# VITE_STA_BASE_URL=
# VITE_STA_ST2_BASE_URL=
# VITE_FEATURES_BASE_URL=
